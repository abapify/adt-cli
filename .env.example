# abapify Pilot — dev environment configuration
# Copy this file to .env and fill in the values.
# .env is gitignored; this file is safe to commit.

# ─── LLM (LiteLLM proxy) ──────────────────────────────────────────────────────
# Base URL of your LiteLLM proxy (OpenAI-compatible API).
LITELLM_BASE_URL=http://127.0.0.1:4000

# API key forwarded to LiteLLM.
LITELLM_API_KEY=sk-your-litellm-key

# Model name as understood by LiteLLM (e.g. openai/gpt-4o, anthropic/claude-3-5-sonnet).
MODEL=openai/gpt-4o

# ─── MCP server ───────────────────────────────────────────────────────────────
# URL of the running adt-mcp HTTP server.
# When using `bun run dev:pilot` both servers start together; this default works.
MCP_SERVER_URL=http://127.0.0.1:3001/mcp

# ─── adt-mcp server settings ──────────────────────────────────────────────────
# Port for the adt-mcp Streamable HTTP server.
MCP_PORT=3001

# Bind address for adt-mcp. Use 127.0.0.1 for local-only access.
MCP_HOST=127.0.0.1

# Allow CORS from the Mastra Playground (localhost:4111).
MCP_CORS_ORIGIN=http://localhost:4111

# ─── adt-mcp multi-system config ──────────────────────────────────────────────
# Path to your adt.config.ts or adt.config.json (SAP system definitions).
# When set, destinations from adt-config are registered in the MCP multi-system registry.
# Credentials are NOT stored — supply them at runtime via sap_connect.
# Relative to packages/adt-mcp/ (or use absolute path).
ADT_CONFIG_FILE=../../adt.config.ts
