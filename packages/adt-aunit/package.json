{
  "name": "@abapify/adt-aunit",
  "version": "0.3.3",
  "description": "ABAP Unit Test CLI plugin for adt-cli with JUnit XML output for GitLab CI",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./commands/aunit": "./dist/commands/aunit.mjs",
    "./formatters/jacoco": "./dist/formatters/jacoco.mjs",
    "./package.json": "./package.json"
  },
  "files": [
