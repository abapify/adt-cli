<?xml version="1.0" encoding="UTF-8"?>
<!--
  RAP Service Definition Source Schema (SRVD)

  GET/POST/PUT /sap/bc/adt/ddic/srvd/sources/{name}
  Content-Type: application/vnd.sap.adt.ddic.srvd.v1+xml

  The root element is <srvd:source> in the http://www.sap.com/adt/ddic/srvd
  namespace and extends abapsource:AbapSourceMainObject (the standard
  ABAP source object base type), so it automatically carries
  adtcore + abapsource metadata (name, package, syntaxConfiguration,
  etc.) via schema composition.

  Source on disk (abapGit-classic): `.asrvd`.
-->
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:srvd="http://www.sap.com/adt/ddic/srvd"
    xmlns:abapsource="http://www.sap.com/adt/abapsource"
    targetNamespace="http://www.sap.com/adt/ddic/srvd"
    elementFormDefault="qualified"
    attributeFormDefault="qualified">

  <xsd:import namespace="http://www.sap.com/adt/abapsource"
              schemaLocation="../sap/abapsource.xsd"/>

  <xsd:element name="source" type="srvd:SrvdSource"/>

  <xsd:complexType name="SrvdSource">
    <xsd:complexContent>
      <xsd:extension base="abapsource:AbapSourceMainObject">
      </xsd:extension>
    </xsd:complexContent>
  </xsd:complexType>

</xsd:schema>
