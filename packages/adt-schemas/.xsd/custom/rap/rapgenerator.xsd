<?xml version="1.0" encoding="UTF-8"?>
<!--
  RAP Generator Schema
  Based on SAP ADT REST API for RAP Generator
  
  Namespace: http://www.sap.com/adt/rap/generator
  Content-Type: application/vnd.sap.adt.rap.generator.v1+xml
  
  Used by: /sap/bc/adt/rap/generator
  
  Note: This schema includes basic types to avoid dependencies on base SAP schemas.
-->
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:atom="http://www.w3.org/2005/Atom"
    targetNamespace="http://www.sap.com/adt/rap/generator"
    elementFormDefault="qualified"
    attributeFormDefault="qualified">

  <!-- Atom namespace for feed elements -->
  <xsd:import namespace="http://www.w3.org/2005/Atom" schemaLocation="atom.xsd"/>

  <!-- Root element for RAP Generator workspace list -->
  <xsd:element name="rapGenerator" type="rapgen:RapGeneratorType"/>

  <!-- Root element for templates list -->
  <xsd:element name="templates" type="rapgen:TemplatesType"/>

  <!-- Root element for single template -->
  <xsd:element name="template" type="rapgen:TemplateType"/>

  <!-- Root element for generation result -->
  <xsd:element name="generationResult" type="rapgen:GenerationResultType"/>

  <!-- RAP Generator workspace type -->
  <xsd:complexType name="RapGeneratorType">
    <xsd:sequence>
      <xsd:element ref="atom:entry" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
    <xsd:attribute name="totalResults" type="xsd:integer" use="optional"/>
    <xsd:attribute name="startIndex" type="xsd:integer" use="optional"/>
  </xsd:complexType>

  <!-- Templates collection type -->
  <xsd:complexType name="TemplatesType">
    <xsd:sequence>
      <xsd:element ref="atom:entry" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
    <xsd:attribute name="totalResults" type="xsd:integer" use="optional"/>
    <xsd:attribute name="startIndex" type="xsd:integer" use="optional"/>
  </xsd:complexType>

  <!-- Template type -->
  <xsd:complexType name="TemplateType">
    <xsd:sequence>
      <xsd:element ref="atom:title" minOccurs="0"/>
      <xsd:element ref="atom:summary" minOccurs="0"/>
      <xsd:element ref="atom:updated" minOccurs="0"/>
      <xsd:element ref="atom:author" minOccurs="0"/>
      <xsd:element ref="atom:link" minOccurs="0" maxOccurs="unbounded"/>
      <xsd:element name="description" type="xsd:string" minOccurs="0"/>
      <xsd:element name="category" type="xsd:string" minOccurs="0"/>
      <xsd:element name="inputParameters" type="rapgen:InputParametersType" minOccurs="0"/>
      <xsd:element name="outputArtifacts" type="rapgen:OutputArtifactsType" minOccurs="0"/>
    </xsd:sequence>
    <xsd:attribute name="name" type="xsd:string" use="required"/>
    <xsd:attribute name="version" type="xsd:string" use="optional"/>
  </xsd:complexType>

  <!-- Input parameters for generation -->
  <xsd:complexType name="InputParametersType">
    <xsd:sequence>
      <xsd:element name="parameter" type="rapgen:InputParameterType" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>

  <!-- Single input parameter -->
  <xsd:complexType name="InputParameterType">
    <xsd:sequence>
      <xsd:element name="name" type="xsd:string"/>
      <xsd:element name="label" type="xsd:string" minOccurs="0"/>
      <xsd:element name="description" type="xsd:string" minOccurs="0"/>
      <xsd:element name="defaultValue" type="xsd:string" minOccurs="0"/>
      <xsd:element name="allowedValues" type="rapgen:AllowedValuesType" minOccurs="0"/>
    </xsd:sequence>
    <xsd:attribute name="type" type="xsd:string" use="required"/>
    <xsd:attribute name="required" type="xsd:boolean" use="optional"/>
  </xsd:complexType>

  <!-- Allowed values for parameter -->
  <xsd:complexType name="AllowedValuesType">
    <xsd:sequence>
      <xsd:element name="value" type="xsd:string" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>

  <!-- Output artifacts generated by template -->
  <xsd:complexType name="OutputArtifactsType">
    <xsd:sequence>
      <xsd:element name="artifact" type="rapgen:OutputArtifactType" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>

  <!-- Single output artifact -->
  <xsd:complexType name="OutputArtifactType">
    <xsd:sequence>
      <xsd:element name="type" type="xsd:string" minOccurs="0"/>
      <xsd:element name="name" type="xsd:string" minOccurs="0"/>
      <xsd:element name="description" type="xsd:string" minOccurs="0"/>
    </xsd:sequence>
    <xsd:attribute name="objectType" type="xsd:string" use="required"/>
  </xsd:complexType>

  <!-- Generation result type -->
  <xsd:complexType name="GenerationResultType">
    <xsd:sequence>
      <xsd:element name="status" type="xsd:string"/>
      <xsd:element name="message" type="xsd:string" minOccurs="0"/>
      <xsd:element name="generatedObjects" type="rapgen:GeneratedObjectsType" minOccurs="0"/>
      <xsd:element name="errors" type="rapgen:ErrorsType" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType>

  <!-- Generated objects -->
  <xsd:complexType name="GeneratedObjectsType">
    <xsd:sequence>
      <xsd:element name="object" type="rapgen:GeneratedObjectType" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>

  <!-- Single generated object -->
  <xsd:complexType name="GeneratedObjectType">
    <xsd:sequence>
      <xsd:element name="name" type="xsd:string" minOccurs="0"/>
      <xsd:element name="type" type="xsd:string" minOccurs="0"/>
      <xsd:element name="path" type="xsd:string" minOccurs="0"/>
    </xsd:sequence>
    <xsd:attribute name="objectType" type="xsd:string" use="required"/>
  </xsd:complexType>

  <!-- Errors during generation -->
  <xsd:complexType name="ErrorsType">
    <xsd:sequence>
      <xsd:element name="error" type="rapgen:GenerationErrorType" minOccurs="0" maxOccurs="unbounded"/>
    </xsd:sequence>
  </xsd:complexType>

  <!-- Single generation error -->
  <xsd:complexType name="GenerationErrorType">
    <xsd:sequence>
      <xsd:element name="message" type="xsd:string"/>
      <xsd:element name="objectName" type="xsd:string" minOccurs="0"/>
      <xsd:element name="line" type="xsd:integer" minOccurs="0"/>
      <xsd:element name="column" type="xsd:integer" minOccurs="0"/>
    </xsd:sequence>
    <xsd:attribute name="severity" type="xsd:string" use="optional"/>
  </xsd:complexType>

</xsd:schema>
