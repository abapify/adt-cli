<?xml version="1.0" encoding="UTF-8"?>
<!--
  CDS Access Control (DCL) Source Schema (DCLS)

  GET/POST/PUT /sap/bc/adt/acm/dcl/sources/{name}
  Content-Type: application/vnd.sap.adt.acm.dcl.source.v1+xml

  The root element is <dcl:source> in the http://www.sap.com/adt/dcl
  namespace and extends abapsource:AbapSourceMainObject.
-->
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
    xmlns:dcl="http://www.sap.com/adt/dcl"
    xmlns:abapsource="http://www.sap.com/adt/abapsource"
    targetNamespace="http://www.sap.com/adt/dcl"
    elementFormDefault="qualified"
    attributeFormDefault="qualified">

  <xsd:import namespace="http://www.sap.com/adt/abapsource"
              schemaLocation="../sap/abapsource.xsd"/>

  <xsd:element name="source" type="dcl:DclSource"/>

  <xsd:complexType name="DclSource">
    <xsd:complexContent>
      <xsd:extension base="abapsource:AbapSourceMainObject">
      </xsd:extension>
    </xsd:complexContent>
  </xsd:complexType>

</xsd:schema>
