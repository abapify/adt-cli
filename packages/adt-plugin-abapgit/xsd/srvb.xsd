<?xml version="1.0" encoding="UTF-8"?>
<!--
  abapGit SRVB (RAP Service Binding) Schema

  Defines the minimal abapGit metadata wrapper for *.srvb.xml files.

  SRVB is metadata-only (unlike BDEF/SRVD which have .abdl/.asrvd source
  text). We only need to serialise the binding key + protocol-relevant
  fields. Rich binding payload (services, implementations) is not
  preserved round-trip — matching the conservative approach used by
  zcl_abapgit_object_srvb.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:asx="http://www.sap.com/abapxml"
           elementFormDefault="unqualified">

  <!-- Import ASX namespace -->
  <xs:import namespace="http://www.sap.com/abapxml" schemaLocation="asx.xsd"/>

  <!-- Include base abapGit types -->
  <xs:include schemaLocation="abapgit.xsd"/>

  <!-- SKEY — binding source key (minimal metadata for abapGit) -->
  <xs:complexType name="SkeyType">
    <xs:all>
      <xs:element name="TYPE" type="xs:string" minOccurs="0"/>
      <xs:element name="NAME" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- BINDING — protocol header block -->
  <xs:complexType name="BindingType">
    <xs:all>
      <xs:element name="TYPE" type="xs:string" minOccurs="0"/>
      <xs:element name="VERSION" type="xs:string" minOccurs="0"/>
      <xs:element name="CATEGORY" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- SRVB-specific values type -->
  <xs:complexType name="SrvbValuesType">
    <xs:all>
      <xs:element name="SKEY" type="SkeyType" minOccurs="0"/>
      <xs:element name="BINDING" type="BindingType" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- SRVB-specific ABAP envelope -->
  <xs:complexType name="SrvbAbapType">
    <xs:sequence>
      <xs:element name="values" type="SrvbValuesType"/>
    </xs:sequence>
    <xs:attribute name="version" type="xs:string" default="1.0"/>
  </xs:complexType>

  <!-- THE ONLY ROOT ELEMENT -->
  <xs:element name="abapGit">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="abap" type="SrvbAbapType"/>
      </xs:sequence>
      <xs:attribute name="version" type="xs:string" use="required"/>
      <xs:attribute name="serializer" type="xs:string" use="required"/>
      <xs:attribute name="serializer_version" type="xs:string" use="required"/>
    </xs:complexType>
  </xs:element>

</xs:schema>
