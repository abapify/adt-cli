<?xml version="1.0" encoding="UTF-8"?>
<!--
  abapGit BDEF (RAP Behavior Definition) Schema

  Defines SKEY (minimal source descriptor) structure for *.bdef.xml files.
  The actual behavior source lives alongside in `<name>.bdef.abdl`.

  The abapGit zcl_abapgit_object_bdef serializer writes only a lightweight
  SKEY metadata block because all semantic content is in the .abdl source.
  We mirror that shape here.
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:asx="http://www.sap.com/abapxml"
           elementFormDefault="unqualified">

  <!-- Import ASX namespace -->
  <xs:import namespace="http://www.sap.com/abapxml" schemaLocation="asx.xsd"/>

  <!-- Include base abapGit types -->
  <xs:include schemaLocation="abapgit.xsd"/>

  <!-- SKEY — RAP behavior source key (minimal metadata for abapGit) -->
  <xs:complexType name="SkeyType">
    <xs:all>
      <xs:element name="TYPE" type="xs:string" minOccurs="0"/>
      <xs:element name="NAME" type="xs:string" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- BDEF-specific values type -->
  <xs:complexType name="BdefValuesType">
    <xs:all>
      <xs:element name="SKEY" type="SkeyType" minOccurs="0"/>
    </xs:all>
  </xs:complexType>

  <!-- BDEF-specific ABAP envelope -->
  <xs:complexType name="BdefAbapType">
    <xs:sequence>
      <xs:element name="values" type="BdefValuesType"/>
    </xs:sequence>
    <xs:attribute name="version" type="xs:string" default="1.0"/>
  </xs:complexType>

  <!-- THE ONLY ROOT ELEMENT -->
  <xs:element name="abapGit">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="abap" type="BdefAbapType"/>
      </xs:sequence>
      <xs:attribute name="version" type="xs:string" use="required"/>
      <xs:attribute name="serializer" type="xs:string" use="required"/>
      <xs:attribute name="serializer_version" type="xs:string" use="required"/>
    </xs:complexType>
  </xs:element>

</xs:schema>
