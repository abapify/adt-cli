{
  "name": "adt-mcp",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/adt-mcp/src",
  "projectType": "library",
  "tags": ["scope:adt", "type:mcp"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "cwd": "packages/adt-mcp",
        "command": "bun dist/bin/adt-mcp-http.mjs",
        "envFile": "{workspaceRoot}/.env"
      }
    },
    "typecheck": {
      "command": "echo 'typecheck disabled: MCP SDK + Zod type inference causes OOM (see adt-mcp/AGENTS.md)'"
    }
  }
}
